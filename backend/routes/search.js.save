const express = require('express');
const router = express.Router();
const { searchPlaces } = require('../services/places');

router.post('/', async (req, res) => {
  const { keyword, zone, radius } = req.body;

  if (!keyword || !zone) {
    return res.status(400).json({ error: 'keyword et zone sont requis' });
  }

  try {
    const { places } = await searchPlaces({ keyword, zone, radius });

    if (places.length === 0) {
      return res.status(404).json({ error: 'Aucun résultat trouvé' });
    }

    res.json({ places });

  } catch (error) {
    console.error('Erreur /search:', error.message);

    if (error.response?.status === 429) {
      return res.status(429).json({ error: 'Quota dépassé' });
    }
    if (error.response?.status === 403) {
      return res.status(403).json({ error: 'Clé API invalide' });
    }

    res.status(500).json({ error: 'Erreur serveur' });
  }
});

module.exports = router;
